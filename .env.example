# memory-mcp configuration
# Copy to .env and fill in your values.
# python-dotenv loads this file automatically on startup.
# All settings are optional — uncomment and change only what you need.

# ── Database ───────────────────────────────────────────────────────────────────
# Default: memory.db next to server.py. Use an absolute path in production so
# the location doesn't depend on the working directory.
#
# MEMORY_DB_PATH=/var/lib/memory-mcp/memory.db

# ── AI backend ─────────────────────────────────────────────────────────────────
# Shared base URL — used for both embeddings and LLM unless overridden below.
# Default points to a local Ollama instance. See docs/ai-backend.md for
# provider examples (OpenAI, LM Studio, Together AI, split backends).

MEMORY_AI_BASE_URL=http://localhost:11434/v1
MEMORY_AI_API_KEY=                           # leave empty for local providers
MEMORY_EMBED_MODEL=nomic-embed-text
MEMORY_EMBED_DIM=768

# Split backend — route LLM calls to a different host than embeddings.
# Useful when running nomic-embed-text on a Raspberry Pi 4 (CPU, always on)
# and a heavier LLM on a GPU machine. Falls back to MEMORY_AI_* when not set.
#
# MEMORY_LLM_BASE_URL=http://gpu-host.local:11434/v1
# MEMORY_LLM_API_KEY=
MEMORY_LLM_MODEL=llama3.2

# AI call timeout in seconds.
# Embedding calls use this directly; LLM calls use max(timeout, 60).
# Increase if using a slow local model or a remote GPU over the LAN.
#
# MEMORY_AI_TIMEOUT=30

# ── API authentication ──────────────────────────────────────────────────────────
# Bearer token required for all API calls (except /health, /admin, /graph).
# Leave blank to let the server auto-generate a token on first startup (stored
# in the database and shown once in the log).
# Manage via the admin UI at /admin/settings.
#
# MEMORY_API_TOKEN=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * to allow all (default).
# Lock this down if the server is reachable beyond localhost or a trusted LAN.
#
# MEMORY_CORS_ORIGINS=*
# MEMORY_CORS_ORIGINS=http://homeassistant.local,http://localhost:3000

# ── Confidence decay ───────────────────────────────────────────────────────────
# Memories decay toward a floor of 0.05 using: conf × 2^(−days / halflife)
# Decay runs hourly in the pattern engine.
#
# Global half-life in days (applies to all categories unless overridden below):
# MEMORY_DECAY_HALFLIFE_DAYS=90
#
# Per-category overrides — must be valid JSON:
# MEMORY_DECAY_CATEGORY_HALFLIFE={"preference": 180, "insight": 30}
#
# Location records decay on a shorter cycle (hours, not days):
# MEMORY_LOCATION_DECAY_HALFLIFE_HOURS=24

# ── Source trust defaults ──────────────────────────────────────────────────────
# Trust tier assigned when no explicit source_trust is provided.
# Scale: 5=user, 4=hardware, 3=system, 2=inferred, 1=external.
# Lower-trust writes cannot supersede higher-trust memories.
#
# MEMORY_TRUST_DEFAULT_REMEMBER=5   # tool_remember / POST /remember / admin UI
# MEMORY_TRUST_DEFAULT_EXTRACT=2    # extract_and_remember (LLM-extracted facts)
# MEMORY_TRUST_DEFAULT_PATTERN=2    # pattern engine promoted insights
# MEMORY_TRUST_DEFAULT_IMPORT=1     # all importers (JSONL, mem0, mcp-memory-service)

# ── Logging ────────────────────────────────────────────────────────────────────
# MEMORY_LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR
# MEMORY_LOG_FORMAT=pretty     # pretty | json  (json = one JSON object per line)

# ── MQTT bridge (integrations/mqtt_bridge.py — separate process) ───────────────
# MEMORY_MQTT_BROKER=your-broker-host
# MEMORY_MQTT_PORT=1883
# MEMORY_MQTT_USER=
# MEMORY_MQTT_PASSWORD=
# MEMORY_MQTT_TOPICS=memory/#
# MEMORY_MQTT_MAPPINGS=integrations/mqtt_mappings.json
# MEMORY_API_URL=http://localhost:8900
